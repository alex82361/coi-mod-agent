# Environment Configuration Template
# Copy this file to .env and fill in values

# Game Paths
COI_ROOT=C:\Games\CaptainOfIndustry
COI_MOD_FOLDER=%APPDATA%\Captain of Industry\Mods

# Mod Configuration
MOD_NAME=CoiModAgent
MOD_VERSION=0.1.0
MOD_DEBUG=true

# Safety & Features
FEATURE_VISION_ENABLED=false
FEATURE_LEARNING_ENABLED=false
SAFETY_DENY_BY_DEFAULT=true
SAFETY_AUDIT_LOG_ENABLED=true

# Logging
LOG_LEVEL=Debug
LOG_FILE_PATH=./logs/coi-mod-agent.log

# Python & RL
PYTHON_ENV_PATH=./python/venv
LEARNING_MODEL_PATH=./models/policy.pkl
LEARNING_OFFLINE_ONLY=true

# Testing
TEST_GAME_VERSION=1.0.0
TEST_COMPATIBILITY_CHECK=true